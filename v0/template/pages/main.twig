{# see WaiBlue\GuideVis\Loader->getPageVars() for the list of available variables #}

<html>
<head>
  {% include('elements/html-head.twig') %}
</head>
<body>
  <div class="top-bar">
    <button type="button" class="top-bar-burger" onclick="toggleMenu()" aria-label="Toggle menu">
      <i class="fas fa-bars"></i>
    </button>
    <a href="https://www.hubleto.eu" target="_blank" class="top-bar-link top-bar-hubleto">www.hubleto.eu</a>
    <a href="https://www.reddit.com/r/hubleto/" target="_blank" class="top-bar-link">
      <i class="fab fa-reddit"></i>
      <span>Reddit</span>
    </a>
    <a href="https://help.hubleto.eu" target="_blank" class="top-bar-link top-bar-desktop">
      <i class="fas fa-circle-question"></i>
      <span>User Guide</span>
    </a>
    <a href="https://stackoverflow.com/questions/tagged/hubleto" target="_blank" class="top-bar-link top-bar-desktop">
      <i class="fab fa-stack-overflow"></i>
      <span>Stack Overflow</span>
    </a>
    <a href="https://www.linkedin.com/company/hubleto" target="_blank" class="top-bar-link top-bar-desktop">
      <i class="fab fa-linkedin"></i>
      <span>LinkedIn</span>
    </a>
    <a href="https://community.hubleto.eu" target="_blank" class="top-bar-link top-bar-desktop">
      <i class="fas fa-users"></i>
      <span>Community</span>
    </a>
    <a href="https://github.com/hubleto/erp/issues" target="_blank" class="top-bar-link top-bar-desktop">
      <i class="fab fa-github"></i>
      <span>Report an issue</span>
    </a>
  </div>
  {% include('elements/sidebar.twig') %}


  <!-- Content -->
  <div class="wrapper">
    <div class="content">
      {{ content|raw }}
      {% if data.searchResults is defined %}
        {% if data.query %}
          <div class="mb-6">
            <p class="text-gray-400 text-sm">Search results for: <strong class="text-gray-100">{{ data.query }}</strong></p>
            <p class="text-gray-500 text-xs mt-1">{{ data.searchResults|length }} result(s) found</p>
          </div>

          {% if data.searchResults|length > 0 %}
            <ul class="space-y-4">
              {% for result in data.searchResults %}
                <li class="border border-gray-700 rounded-lg p-4 hover:border-blue-500 hover:shadow-sm transition-all">
                  <a href="{{ result.url }}" class="text-blue-400 hover:underline font-semibold text-base">{{ result.titleDisplay|raw }}</a>
                  {% if data.debugSearch %}
                    <span class="text-xs text-gray-400 ml-2 font-mono">
                      score: {{ result.score }} | count: {{ result.count }} | priority: {{ result.priority }} | boost: {{ result.boost }}
                    </span>
                  {% endif %}
                  <span class="text-xs text-gray-500 ml-2">({{ result.count }} matches)</span>
                  {% if result.snippets|length > 0 %}
                    <div class="mt-2 space-y-1">
                      {% for snippet in result.snippets %}
                        <p class="text-sm text-gray-300 border-l-2 border-gray-600 pl-3">{{ snippet|raw }}</p>
                      {% endfor %}
                    </div>
                  {% endif %}
                </li>
              {% endfor %}
            </ul>
          {% else %}
            <div class="text-center py-12">
              <p class="text-gray-300 text-lg">No results found for <strong>{{ data.query }}</strong></p>
              <p class="text-gray-400 text-sm mt-2">Try different keywords</p>
            </div>
          {% endif %}
        {% endif %}
      {% endif %}
    </div>

    {% if pageConfig.tocData.prevPageData or pageConfig.tocData.nextPageData %}
      <div class="content flex justify-between">
        <div class="flex-1 text-left">
          {% if pageConfig.tocData.prevPageData %}
            <a href="{{ env.guideRootUrl }}/{{ pageConfig.tocData.prevPageData.page }}">&laquo; Previous page</a><br/>
            <small>{{ pageConfig.tocData.prevPageData.title }}</small>
          {% endif %}
        </div>
        <div class="flex-1 text-right">
          {% if pageConfig.tocData.nextPageData %}
            <a href="{{ env.guideRootUrl }}/{{ pageConfig.tocData.nextPageData.page }}">Next page &raquo;</a><br/>
            <small>{{ pageConfig.tocData.nextPageData.title }}</small>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>

  {% include('elements/on-this-page.twig') %}
  {% include('elements/footer.twig') %}

  <script src="{{ guideRootUrl }}/node_modules/preline/dist/preline.js"></script>

  <script>hljs.highlightAll();</script>

  <script>
    window.addEventListener('DOMContentLoaded', () => {
      const header = document.querySelector('.header');
      const headerHeight = header ? header.offsetHeight : 0;

      // Wrap heading text in a span for precise highlight
      const headings = document.querySelectorAll('.content h1, .content h2, .content h3, .content h4');
      headings.forEach(h => {
        if (!h.id) {
          h.id = h.textContent.trim();
        }

        // Wrap text in span if not already wrapped
        if (!h.querySelector('.heading-text')) {
          const span = document.createElement('span');
          span.className = 'heading-text';
          span.style.position = 'relative';
          span.style.display = 'inline-block'; // so width matches text
          while (h.firstChild) {
            span.appendChild(h.firstChild);
          }
          h.appendChild(span);
        }
      });

      const scrollToHeading = (target) => {
        if (!target) return;

        // Remove previous highlights
        document.querySelectorAll('.highlight-pill').forEach(pill => pill.remove());

        const span = target.querySelector('.heading-text');
        if (!span) return;

        // Scroll with sticky header offset
        const top = target.getBoundingClientRect().top + window.scrollY - headerHeight - 8;
        window.scrollTo({ top, behavior: 'smooth' });

        // Create pill slightly bigger than the text
        const overlay = document.createElement('span');
        overlay.className = 'highlight-pill';
        overlay.style.position = 'absolute';
        overlay.style.left = '-0.2em';  // extend a bit beyond text
        overlay.style.right = '-0.2em';
        overlay.style.bottom = '0.1em'; // just under the text
        overlay.style.height = '0.8em';  // slightly taller
        overlay.style.backgroundColor = '#1d4ed8';
        overlay.style.borderRadius = '0.4em'; // rounded edges
        overlay.style.zIndex = '-1';
        overlay.style.transition = 'opacity 0.5s';

        span.appendChild(overlay);

        // Fade out after 2 seconds
        setTimeout(() => {
          overlay.style.opacity = '0';
          setTimeout(() => {
            if (overlay.parentNode) overlay.parentNode.removeChild(overlay);
          }, 500);
        }, 2000);
      };

      // Anchor click handler
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', (e) => {
          const hash = decodeURIComponent(anchor.getAttribute('href').substring(1));
          const target = document.getElementById(hash);
          if (!target) return;
          e.preventDefault();
          scrollToHeading(target);
          history.pushState(null, '', `#${encodeURIComponent(hash)}`);
        });
      });

      // Scroll to hash on page load
      if (window.location.hash) {
        const hash = decodeURIComponent(window.location.hash.substring(1));
        const target = document.getElementById(hash);
        if (target) {
          setTimeout(() => scrollToHeading(target), 50);
        }
      }
    });
  </script>

</body>
</html>
